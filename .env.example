# Frontend Configuration Template
# Copy to frontend/.env.local and update with your values

# REQUIRED: Your deployed ERC-20 contract address
VITE_CONTRACT_ADDRESS=0x...

# OPTIONAL: Custom RPC provider (defaults to MetaMask)
VITE_RPC_URL=https://sepolia.infura.io/v3/YOUR_KEY

# OPTIONAL: Network chain ID (auto-detected)
VITE_NETWORK_ID=11155111
